generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
  FARMER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DeliveryMethod {
  LOGISTICS
  SELF_PICKUP
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole
  phone        String?
  gender       String?
  birthDate    DateTime?
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  addresses    Address[]
  bankAccounts BankAccount[]
  products     Product[]
  orders       Order[]       @relation("CustomerOrders")
  soldOrders   Order[]       @relation("FarmerOrders")
}

model Address {
  id            String   @id @default(cuid())
  userId        String
  label         String
  recipientName String
  phoneNumber   String
  fullAddress   String
  city          String
  province      String
  isMain        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        Order[]

  @@index([userId])
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  accountNumber String
  accountHolder String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerOrders Order[] @relation("OrderCustomerBank")
  farmerOrders   Order[] @relation("OrderFarmerBank")

  @@index([userId])
  @@unique([userId, accountNumber])
}

model Product {
  id          String           @id @default(cuid())
  farmerId    String
  name        String
  description String?
  price       Decimal          @db.Decimal(12, 2)
  stock       Decimal          @db.Decimal(12, 3)
  image       String?
  status      String           @default("Ready")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  farmer      User             @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  images      ProductImage[]

  @@index([farmerId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model FarmerProfile {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  farmerName    String
  profilePhoto  String?
  catalogBanner String?
  description   String?
  catalogMapUrl String?
  latitude      Float    @default(0)
  longitude     Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  histories     FarmerProfileHistory[]

  @@index([tenantId])
}

model FarmerProfileHistory {
  id         String   @id @default(cuid())
  tenantId   String
  profileId  String
  changedBy  String?
  summary    String
  snapshot   Json?
  createdAt  DateTime @default(now())
  profile    FarmerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([profileId])
}

model LogisticsVehicle {
  id          String   @id @default(cuid())
  name        String   @unique
  vehicleType String
  capacityTon Decimal  @db.Decimal(10, 2)
  price       Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id                    String             @id @default(cuid())
  trackingId            String             @unique
  customerId            String
  farmerId              String
  logisticsVehicleId    String?
  customerBankAccountId String?
  farmerBankAccountId   String?
  addressId             String?
  status                OrderStatus        @default(PENDING)
  deliveryMethod        DeliveryMethod     @default(LOGISTICS)
  subtotal              Decimal            @db.Decimal(14, 2)
  logisticsCost         Decimal            @db.Decimal(14, 2) @default(0)
  discountPercentage    Int                @default(0) // 35 for 35% discount
  total                 Decimal            @db.Decimal(14, 2)
  currentLat            Float?
  currentLng            Float?
  estimatedArrival      DateTime?
  notes                 String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  customer              User               @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: Cascade)
  farmer                User               @relation("FarmerOrders", fields: [farmerId], references: [id], onDelete: Cascade)
  logisticsVehicle      LogisticsVehicle?  @relation(fields: [logisticsVehicleId], references: [id], onDelete: SetNull)
  customerBankAccount   BankAccount?       @relation("OrderCustomerBank", fields: [customerBankAccountId], references: [id], onDelete: SetNull)
  farmerBankAccount     BankAccount?       @relation("OrderFarmerBank", fields: [farmerBankAccountId], references: [id], onDelete: SetNull)
  address               Address?           @relation(fields: [addressId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  trackingPoints        TrackingPoint[]
  payment               Payment?
  messages              OrderMessage[]

  @@index([customerId])
  @@index([farmerId])
  @@index([trackingId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantityKg Int
  unitPrice Decimal  @db.Decimal(12, 2)
  subtotal  Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model TrackingPoint {
  id        String   @id @default(cuid())
  orderId   String
  latitude  Float
  longitude Float
  note      String?
  recordedAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, recordedAt])
}

model PartnershipInquiry {
  id           String   @id @default(cuid())
  name         String
  phone        String
  role         String
  landArea     String?
  location     String?
  monthlyNeeds String?
  commodity    String?
  notes        String?
  status       String   @default("NEW")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  QRIS
  E_WALLET
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(14, 2)
  method          PaymentMethod @default(QRIS)
  status          PaymentStatus @default(PENDING)
  midtransTransactionId String?
  midtransUrl     String?
  paidAt          DateTime?
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

model OrderMessage {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender    String   // "ADMIN" or "FARMER"
  message   String
  status    String   @default("UNREAD") // UNREAD, READ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}
